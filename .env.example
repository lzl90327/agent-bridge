# 数据库
# 开发环境可以使用内存数据库: DATABASE_URL=memory
# 生产环境使用 PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/agent_bridge
DATABASE_URL=memory

# Redis
# 开发环境可以留空使用内存存储
# 生产环境: REDIS_URL=redis://localhost:6379
REDIS_URL=

# OpenClaw
OPENCLAW_URL=http://localhost:18889
OPENCLAW_API_KEY=

# 服务端口
PORT=3000

# 日志级别
LOG_LEVEL=info

# JWT 密钥
JWT_SECRET=your-jwt-secret-here

# 环境
NODE_ENV=development
